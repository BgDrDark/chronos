{
  "extends": "./tsconfig.app.json",
  "compilerOptions": {
    "composite": true,
    "tsBuildInfoFile": "./node_modules/.dotcache/tsconfig.test.tsbuildinfo",
    "verbatimModuleSyntax": false,
    "jsx": "react-jsx",
    "esModuleInterop": true,
    "types": ["vitest/globals", "node", "vite/client"]
  },
  "include": ["src"],
  "exclude": ["node_modules", "**/*.test.tsx", "**/*.test.ts"]
}
